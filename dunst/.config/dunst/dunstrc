[global]
    monitor = 0
    follow = none

    # 렌더링 억제 — eww가 UI 담당
    width = 0
    height = 0
    offset = 0x0
    transparency = 100
    notification_limit = 0
    idle_threshold = 0

    # 스크립트 브릿지
    always_run_script = true

    # 아이콘
    icon_path = /usr/share/icons/Papirus/48x48/apps:/usr/share/icons/hicolor/48x48/apps:/usr/share/pixmaps
    enable_recursive_icon_lookup = true
    icon_theme = "Papirus, hicolor"

    # 히스토리
    sticky_history = no
    history_length = 0

    # 알림 스택
    indicate_hidden = no
    stack_duplicates = true
    hide_duplicate_count = true

[urgency_low]
    timeout = 5
    script = /home/yozumina/.config/eww/scripts/notify.sh

[urgency_normal]
    timeout = 8
    script = /home/yozumina/.config/eww/scripts/notify.sh

[urgency_critical]
    timeout = 0
    script = /home/yozumina/.config/eww/scripts/notify.sh

[zz-skip-all]
    appname = ".*"
    skip_display = true
